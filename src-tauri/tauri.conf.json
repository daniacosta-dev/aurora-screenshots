{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurora Screenshots",
  "version": "0.3.0",
  "identifier": "com.daniacosta.aurora-screenshots",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../public/aurora-screenshots-icon.svg": "aurora-screenshots-icon.svg"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
